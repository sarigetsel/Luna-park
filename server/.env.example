MONGO_URI=mongodb://127.0.0.1:27017/luna-park
JWT_SECRET=change-me-in-production
PORT=3000
NODE_ENV=development
FULL_DAY_PRICE=50
HOURLY_RATE=15
UPLOAD_DIR=uploads

# Admin user — created automatically on first server start if not exists
ADMIN_NAME=מנהל לונה פארק
ADMIN_EMAIL=admin@luna-park.local
ADMIN_PASSWORD=change-me-admin

# Email — בפיתוח נשלח אוטומטית דרך Ethereal (תצוגה מקדימה בדפדפן)
# למייל אמיתי (Gmail לדוגמה):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=לונה פארק <noreply@luna-park.local>

# Allowed frontend origins (comma-separated) — include all GitHub Pages domains used by the team
CLIENT_ORIGINS=http://localhost:4200,http://localhost:4300,https://sarigetsel.github.io,https://avigailrapa.github.io
